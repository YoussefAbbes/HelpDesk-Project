# ============================================================
# HelpDesk AI — Environment Configuration
# Copy this file to .env and fill in the values.
# ============================================================

# Django
SECRET_KEY=django-insecure-replace-this-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=helpdesk_db
DB_USER=helpdesk_user
DB_PASSWORD=helpdesk_pass
DB_HOST=localhost
DB_PORT=5432

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# CORS — allowed origins for the React frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
DJANGO_LOG_LEVEL=INFO

# AI Model configuration (optional — defaults are set in settings.py)
# AI_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
# AI_CATEGORY_MODEL=facebook/bart-large-mnli
# AI_REPLY_MODEL=google/flan-t5-base

# Directory to cache downloaded Hugging Face models
AI_MODELS_CACHE_DIR=./ai_models_cache
